---
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogType?: string;
}

const SITE = 'https://beaconsfieldinsulation.com.au';
const PHONE_DISPLAY = '(03) 9003 0108';
const PHONE_TEL = '+61390030108';
const EMAIL = 'quotes@beaconsfieldinsulation.com.au';
const BIZ_NAME = 'Beaconsfield Insulation';

const { title, description, canonical = SITE + '/', ogType = 'website' } = Astro.props;

const localBusinessSchema = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "@id": SITE + "/#business",
  "name": BIZ_NAME,
  "image": SITE + "/images/og-image.jpg",
  "url": SITE,
  "telephone": PHONE_TEL,
  "priceRange": "$$",
  "description": "Ceiling, wall, underfloor, roof and acoustic insulation contractors for Beaconsfield, Officer, Pakenham, Cardinia Lakes and Heritage Springs. NatHERS 7-star upgrades, VIC Energy Upgrades rebate-eligible installs, AS/NZS 4859 compliant, ICANZ-aligned. Earthwool, Bradford and Knauf batts.",
  "areaServed": [
    { "@type": "City", "name": "Beaconsfield", "containedInPlace": { "@type": "AdministrativeArea", "name": "Cardinia Shire" } },
    { "@type": "City", "name": "Cardinia Lakes" },
    { "@type": "City", "name": "Officer" },
    { "@type": "City", "name": "Pakenham" },
    { "@type": "City", "name": "Heritage Springs" },
    { "@type": "City", "name": "Berwick" },
    { "@type": "City", "name": "Beaconsfield Upper" },
    { "@type": "City", "name": "Nar Nar Goon" },
    { "@type": "City", "name": "Officer South" }
  ],
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Beaconsfield",
    "addressRegion": "VIC",
    "postalCode": "3807",
    "addressCountry": "AU"
  },
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": -37.9989,
    "longitude": 145.3611
  },
  "openingHoursSpecification": [{
    "@type": "OpeningHoursSpecification",
    "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday","Saturday"],
    "opens": "07:00",
    "closes": "18:00"
  }],
  "hasOfferCatalog": {
    "@type": "OfferCatalog",
    "name": "Ceiling, Wall, Underfloor, Roof & Acoustic Insulation Services",
    "itemListElement": [
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Ceiling Insulation" }},
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Wall Insulation" }},
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Underfloor Insulation" }},
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Roof Insulation" }},
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Acoustic Insulation" }}
    ]
  }
};

const websiteSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "@id": SITE + "/#website",
  "url": SITE + "/",
  "name": BIZ_NAME,
  "inLanguage": "en-AU",
  "publisher": { "@id": SITE + "/#business" }
};
// BreadcrumbList JSON-LD auto-generated from Astro.url.pathname
const pathname = Astro.url.pathname;
const breadcrumbSegments = pathname.split('/').filter(Boolean);
const breadcrumbItems = [{ "@type": "ListItem", "position": 1, "name": "Home", "item": SITE + "/" }];
let cumulative = SITE;
breadcrumbSegments.forEach((seg, i) => {
  cumulative += '/' + seg;
  // Human-friendly name: kebab → Title Case, special-case 'services' → Services
  const friendly = seg === 'services'
    ? 'Services'
    : seg.replace(/-/g, ' ').replace(/\b\w/g, (c) => c.toUpperCase());
  breadcrumbItems.push({
    "@type": "ListItem",
    "position": i + 2,
    "name": friendly,
    "item": cumulative + '/'
  });
});
const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": breadcrumbItems
};

---
<!DOCTYPE html>
<html lang="en-AU">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{title}</title>
  <meta name="description" content={description}>
  <link rel="canonical" href={canonical}>
  <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1">
  <meta name="theme-color" content="#1F3A33">

  <meta property="og:type" content={ogType}>
  <meta property="og:title" content={title}>
  <meta property="og:description" content={description}>
  <meta property="og:url" content={canonical}>
  <meta property="og:locale" content="en_AU">
  <meta property="og:site_name" content={BIZ_NAME}>
  <meta property="og:image" content={SITE + "/images/og-image.jpg"}>
  <meta property="og:image:secure_url" content={SITE + "/images/og-image.jpg"}>
  <meta property="og:image:type" content="image/jpeg">
  <meta property="og:image:width" content="1200">
  <meta property="og:image:height" content="630">
  <meta property="og:image:alt" content={BIZ_NAME + " — free quote, call today"}>

  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content={title}>
  <meta name="twitter:description" content={description}>
  <meta name="twitter:image" content={SITE + "/images/og-image.jpg"}>
  <meta name="twitter:image:alt" content={BIZ_NAME + " — free quote, call today"}>

  <link rel="icon" type="image/x-icon" href="/favicon.ico">
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png">
  <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png">
  <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png">
  <link rel="manifest" href="/site.webmanifest">

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;800&family=Playfair+Display:wght@900&family=Stardos+Stencil:wght@700&display=swap">

  <meta name="google-site-verification" content="NcHyUdUlpAh7C4rMei2M6WYJ3sfJjEwK_YP7WgsWtmQ">

  <script async src="https://www.googletagmanager.com/gtag/js?id=G-XXXXXXXXXX"></script>
  <script is:inline>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', 'G-XXXXXXXXXX', {
      'send_page_view': true,
      'anonymize_ip': true
    });
  </script>

  <script type="application/ld+json" set:html={JSON.stringify(localBusinessSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />

  <slot name="head" />
</head>
<body class="site-beaconsfieldinsulation narrative-the_crew fv-3">
